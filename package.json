{
    "name": "openapi2ts",
    "version": "0.1.0",
    "description": "OpenAPI to TypeScript client generator. Only the TypeScript compiler is required as a dependency (peer). Node 24+, JSON only. Ships raw TypeScript",
    "license": "MIT",
    "bin": {
        "openapi2ts": "./src/cli/index.ts"
    },
    "files": [
        "src",
        "index.d.ts",
        "openapi.d.ts",
        "openapi-client.d.ts",
        "LICENSE",
        "README.md"
    ],
    "type": "module",
    "main": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./src/index.ts"
        },
        "./openapi": {
            "types": "./src/openapi.ts",
            "default": "./src/openapi.ts"
        },
        "./openapi-client": {
            "types": "./src/openapi-client.ts",
            "default": "./src/openapi-client.ts"
        }
    },
    "scripts": {
        "generate": "node src/cli/index.ts generate",
        "check": "node src/cli/index.ts check",
        "test": "node --test test/node/*.test.ts",
        "lint": "tsc --noEmit",
        "test:update": "node src/cli/index.ts generate test/snapshot-config.ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {},
    "devDependencies": {
        "@types/node": "^24.0.0",
        "typescript": "^6.0.0"
    },
    "peerDependencies": {
        "typescript": ">=6.0.0"
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
